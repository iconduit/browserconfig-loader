{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "artifacts/dist",
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "outDir": "artifacts/dist",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  }
}
